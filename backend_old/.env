APP_NAME=FacultyUp
APP_ENV=local
APP_KEY=base64:GENERATE_THIS_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MongoDB Configuration
DB_CONNECTION=mongodb
DB_HOST=127.0.0.1
DB_PORT=27017
DB_DATABASE=facultyup_db
DB_USERNAME=
DB_PASSWORD=

# Mail / Nodemailer style via SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@facultyup.lpu.in
MAIL_FROM_NAME="FacultyUp LPU"

# JWT
JWT_SECRET=GENERATE_THIS_WITH_php_artisan_jwt_secret
JWT_TTL=1440

# File Storage
FILESYSTEM_DISK=local
MAX_FILE_SIZE=10240

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OTP Expiry in minutes
OTP_EXPIRY=10

SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost
